<Window x:Class="QuickViewFile.OverwriteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Exists" Height="200" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Name="QuestionTextBlock" Text="File already exists. What do you want to do?" Grid.Row="0" TextWrapping="Wrap" FontSize="14"/>
        <CheckBox Name="DoForAllCheckBox" Content="Do this for all conflicts in this session" Grid.Row="1" Margin="0,10,0,15" FontSize="14"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Replace" Width="80" Click="ReplaceButton_Click" Margin="0,0,10,0"/>
            <Button Content="Auto Rename" Width="100" Click="AutoRenameButton_Click" Margin="0,0,10,0"/>
            <Button Content="Skip" Width="80" Click="SkipButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>